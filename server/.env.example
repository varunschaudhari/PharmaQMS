PORT=4000
MONGODB_URI=mongodb://localhost:27017/pharmaqms
REDIS_URL=redis://localhost:6379

JWT_ACCESS_SECRET=change-me
JWT_ACCESS_TTL=15m
JWT_REFRESH_SECRET=change-me
JWT_REFRESH_TTL_DEFAULT=12h
JWT_REFRESH_TTL_REMEMBERED=30d
JWT_SIGNING_SECRET=change-me

AUTH_LOCKOUT_MAX_ATTEMPTS=5
AUTH_LOCKOUT_DURATION_MINUTES=30

AUTH_PASSWORD_MIN_LENGTH=8
AUTH_PASSWORD_REQUIRE_UPPERCASE=true
AUTH_PASSWORD_REQUIRE_LOWERCASE=true
AUTH_PASSWORD_REQUIRE_NUMBER=true
AUTH_PASSWORD_REQUIRE_SPECIAL_CHAR=true
AUTH_PASSWORD_EXPIRY_DAYS=90

# PLT-3: e-signature credential re-check. 'pin' is not yet implemented (see esign.config.ts).
SIGNATURE_CREDENTIAL_TYPE=password
# Hard-capped in code at 120s (≤2 min per SPEC.md §5.2) regardless of this value.
SIGNING_TOKEN_TTL_SECONDS=120

TENANT_DEFAULT_TIMEZONE=Asia/Kolkata
