PORT=4000
MONGODB_URI=mongodb://localhost:27017/pharmaqms
REDIS_URL=redis://localhost:6379

JWT_ACCESS_SECRET=change-me
JWT_ACCESS_TTL=15m
JWT_REFRESH_SECRET=change-me
JWT_REFRESH_TTL_DEFAULT=12h
JWT_REFRESH_TTL_REMEMBERED=30d
JWT_SIGNING_SECRET=change-me

AUTH_LOCKOUT_MAX_ATTEMPTS=5
AUTH_LOCKOUT_DURATION_MINUTES=30

AUTH_PASSWORD_MIN_LENGTH=8
AUTH_PASSWORD_REQUIRE_UPPERCASE=true
AUTH_PASSWORD_REQUIRE_LOWERCASE=true
AUTH_PASSWORD_REQUIRE_NUMBER=true
AUTH_PASSWORD_REQUIRE_SPECIAL_CHAR=true
AUTH_PASSWORD_EXPIRY_DAYS=90

# PLT-3: e-signature credential re-check. 'pin' is not yet implemented (see esign.config.ts).
SIGNATURE_CREDENTIAL_TYPE=password
# Hard-capped in code at 120s (≤2 min per SPEC.md §5.2) regardless of this value.
SIGNING_TOKEN_TTL_SECONDS=120

TENANT_DEFAULT_TIMEZONE=Asia/Kolkata

# PLT-6-WA: WhatsApp notification channel. transport is 'console' (dev, logs only), 'file' (dev,
# appends to WHATSAPP_OUTBOX_PATH), or 'meta' (real Meta WhatsApp Cloud API — requires the
# credentials below). Credentials are never hardcoded/tenant-stored — env config only.
WHATSAPP_TRANSPORT=console
WHATSAPP_OUTBOX_PATH=whatsapp-outbox.ndjson
WHATSAPP_API_BASE_URL=https://graph.facebook.com/v20.0
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_TEMPLATE_LANGUAGE=en
# Shared secret Meta's webhook subscription handshake must present back (GET .../webhook).
WHATSAPP_WEBHOOK_VERIFY_TOKEN=change-me
# Verifies the X-Hub-Signature-256 header on Meta's delivery-status POST callbacks — set this in
# any environment reachable by Meta (unsigned POSTs are accepted only when this is unset, for
# local dev where Meta never actually calls the webhook).
WHATSAPP_APP_SECRET=
WHATSAPP_RATE_LIMIT_PER_SECOND=20
